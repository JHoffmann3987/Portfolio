---
interface Props {
  slug: string;
  emoji?: string;
  title: string;
  description: string;
}

const { slug, emoji, title, description } = Astro.props;
---

<div class="card">
  <h3>{emoji ? `${emoji} ` : ""}{title}</h3>
  <p>{description}</p>
  <a href={`/projects/${slug}`}>Learn More →</a>
</div>

<style>
.card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 24px;
  transition: 0.2s;
}

.card:hover {
  border-color: var(--primary);
  transform: translateY(-4px);
}

h3 {
  margin-top: 0;
  color: var(--text);
}

p {
  color: var(--muted);
  line-height: 1.6;
}

a {
  color: var(--primary-light);
  text-decoration: none;
  font-weight: 600;
}
</style>