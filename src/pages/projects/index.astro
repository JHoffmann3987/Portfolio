---
import Layout from "../../layouts/Layout.astro";

const projects = [
  {
    title: "Proxmox Home Lab",
    status: "Featured",
    description:
      "Enterprise-style home lab built with Proxmox VE, Linux, Docker, and self-hosted services.",
    technologies: ["Proxmox", "Linux", "Docker", "Networking"],
    href: "/projects/proxmox-homelab",
  },
  {
    title: "Docker Services",
    status: "In Progress",
    description:
      "Self-hosted applications including Jellyfin, Sonarr, Radarr, Prowlarr, Homepage, and Nginx Proxy Manager.",
    technologies: ["Docker", "Jellyfin", "Nginx", "Linux"],
    href: "/projects/docker-services",
  },
  {
    title: "PowerShell Automation",
    status: "In Progress",
    description:
      "PowerShell scripts created to automate IT administration and troubleshooting tasks.",
    technologies: ["PowerShell", "Windows", "Automation"],
    href: "/projects/powershell-automation",
  },
  {
    title: "Networking Lab",
    status: "In Progress",
    description:
      "Hands-on networking lab focused on VLANs, routing, switching, and infrastructure.",
    technologies: ["Cisco", "VLANs", "Routing"],
    href: "/projects/networking-lab",
  },
  {
    title: "Microsoft 365 & MSP Experience",
    status: "In Progress",
    description:
      "A showcase of Microsoft 365 administration and troubleshooting performed in an MSP environment.",
    technologies: ["Microsoft 365", "Entra ID", "Exchange"],
    href: "/projects/microsoft-365",
  },
];
---

<Layout title="Projects | Justin Hoffmann">
  <section class="projects">
    <h1>Projects</h1>

    <p class="intro">
      My home lab and technical projects demonstrate how I apply the
      technologies I use professionally while continuing to build hands-on
      experience with virtualization, Linux, Docker, networking, automation, and
      Microsoft infrastructure.
    </p>

    <div class="grid">
      {
        projects.map((project) => (
          <article class="card">
            <span
              class:list={[
                "status",
                {
                  featured: project.status === "Featured",
                  progress: project.status === "In Progress",
                },
              ]}
            >
              {project.status}
            </span>

            <h2>{project.title}</h2>

            <p>{project.description}</p>

            <div class="tech-list">
              {project.technologies.map((tech) => (
                <span class="tech">{tech}</span>
              ))}
            </div>

            <a href={project.href}>View Project →</a>
          </article>
        ))
      }
    </div>
  </section>
</Layout>

<style>
  .projects {
    max-width: 1000px;
    margin: 80px auto;
    padding: 2rem;
  }

  .projects h1 {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .intro {
    max-width: 750px;
    line-height: 1.8;
    color: #cbd5e1;
    margin-bottom: 3rem;
  }

  .grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  }

  .card {
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 12px;
    padding: 1.5rem;
    transition: all 0.25s ease;
  }

  .card:hover {
    transform: translateY(-6px);
    border-color: #3b82f6;
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.35);
  }

  .status {
    display: inline-block;
    color: white;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .status.featured {
    background: #22c55e;
  }

  .status.progress {
    background: #2563eb;
  }

  .card h2 {
    margin-bottom: 0.75rem;
  }

  .card p {
    color: #cbd5e1;
    line-height: 1.7;
  }

  .tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 1.25rem 0;
  }

  .tech {
    background: #0f172a;
    border: 1px solid #334155;
    color: #cbd5e1;
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    font-size: 0.8rem;
  }

  .card a {
    display: inline-block;
    margin-top: 0.5rem;
    color: #60a5fa;
    text-decoration: none;
    font-weight: 600;
    transition: color 0.2s ease;
  }

  .card a:hover {
    color: white;
  }
</style>
