---
import Layout from "../layouts/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";
---

<Layout title="Justin Hoffmann | Portfolio">
  <main class="hero">
    <h1>Justin Hoffmann</h1>

    <p class="subtitle">
      Building reliable IT infrastructure through hands-on projects and continuous learning.
    </p>

    <p class="intro">
      I'm an IT professional passionate about systems administration,
      virtualization, networking, and automation. This portfolio showcases my
      homelab, technical projects, and the skills I'm developing through
      continuous hands-on experience with enterprise infrastructure.
    </p>

    <div class="buttons">
      <a href="/projects">View Projects</a>
      <a href="/about">About Me</a>
    </div>

    <section class="projects">
      <h2>Featured Projects</h2>

      <div class="grid">
        <ProjectCard
          title="Proxmox Home Lab"
          description="Enterprise virtualization environment hosting Linux virtual machines, Docker containers, and self-hosted services used to build practical systems administration skills."
        />

        <ProjectCard
          title="Docker Infrastructure"
          description="Containerized applications including Jellyfin, Homepage, qBittorrent, and other self-hosted services managed through Docker."
        />

        <ProjectCard
          title="Networking Lab"
          description="Hands-on experience with VLANs, managed switches, routing, Cisco equipment, and enterprise networking concepts."
        />

        <ProjectCard
          title="PowerShell Automation"
          description="PowerShell scripts for Windows administration, troubleshooting, reporting, and everyday IT automation."
        />
      </div>
    </section>
  </main>
</Layout>

<style>
.hero {
  max-width: 1000px;
  margin: 80px auto;
  padding: 2rem;
  text-align: center;
}

h1 {
  font-size: 4rem;
  margin-bottom: 0.5rem;
}

.subtitle {
  font-size: 1.4rem;
  color: #4f7cff;
  margin-bottom: 2rem;
  font-weight: 600;
}

.intro {
  font-size: 1.15rem;
  line-height: 1.8;
  color: #cbd5e1;
  max-width: 750px;
  margin: 0 auto 2.5rem;
}

.buttons {
  display: flex;
  justify-content: center;
  gap: 1rem;
  flex-wrap: wrap;
  margin-bottom: 5rem;
}

.buttons a {
  background: #2563eb;
  color: white;
  text-decoration: none;
  padding: 0.9rem 1.7rem;
  border-radius: 10px;
  font-weight: 600;
  transition: 0.2s ease;
}

.buttons a:hover {
  background: #1d4ed8;
  transform: translateY(-2px);
}

.projects {
  margin-top: 3rem;
}

.projects h2 {
  font-size: 2.2rem;
  margin-bottom: 2rem;
}

.grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: 24px;
}
</style>