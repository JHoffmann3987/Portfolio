---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact | Justin Hoffmann">
  <section class="contact">
    <h1>Contact</h1>

    <p class="intro">
      Thanks for visiting my portfolio. If you'd like to connect, discuss an
      opportunity, or talk about technology, I'd be happy to hear from you.
    </p>

    <div class="contact-card">
      <h2>Get in Touch</h2>

      <p>
        <strong>Email</strong><br />
        <a href="mailto:JHoffmann3987@yahoo.com">JHoffmann3987@yahoo.com</a>
      </p>

      <p>
        <strong>GitHub</strong><br />
        <a
          href="https://github.com/jhoffmann3987"
          target="_blank"
          rel="noopener noreferrer"
        >
          github.com/jhoffmann3987
        </a>
      </p>
    </div>
  </section>
</Layout>

<style>
.contact {
  max-width: 800px;
  margin: 80px auto;
  padding: 2rem;
}

.contact h1 {
  font-size: 3rem;
  margin-bottom: 1rem;
}

.intro {
  font-size: 1.1rem;
  line-height: 1.8;
  color: #cbd5e1;
  margin-bottom: 2.5rem;
}

.contact-card {
  background: #1e293b;
  border: 1px solid #334155;
  border-radius: 12px;
  padding: 2rem;
}

.contact-card h2 {
  margin-top: 0;
  margin-bottom: 1.5rem;
}

.contact-card p {
  margin-bottom: 1.5rem;
  line-height: 1.6;
}

.contact-card a {
  color: #60a5fa;
  text-decoration: none;
}

.contact-card a:hover {
  text-decoration: underline;
}
</style>